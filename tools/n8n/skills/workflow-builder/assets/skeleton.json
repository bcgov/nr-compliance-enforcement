  "name": "triage-skeleton",
  "nodes": [
    {
      "id": "note-prod-url",
      "name": "Production URL",
      "parameters": {
        "color": 4,
        "content": "## <TITLE> — production URL\n\nClick to run this triage — read-only and idempotent, safe to fire any time:\n\n**<BASE_URL>/webhook/<PATH>?<QUERY>**\n\nBuilt from cleaned snippets by the workflow-builder skill.",
        "height": 240,
        "width": 380
      },
      "position": [
        180,
        60
      ],
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1
    },
    {
      "id": "webhook",
      "name": "Webhook",
      "parameters": {
        "httpMethod": "GET",
        "options": {},
        "path": "triage",
        "responseMode": "responseNode"
      },
      "position": [
        260,
        320
      ],
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "webhookId": "webhook"
    },
    {
      "id": "step-1",
      "name": "Collect",
      "notes": "What this collection snippet fetches.",
      "parameters": {
        "command": "=NAMESPACE={{ ($('Webhook').item.json.query||{}).namespace }} <snippet>.sh"
      },
      "position": [
        480,
        320
      ],
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1
    },
    {
      "id": "merge-snippets",
      "name": "Merge snippets",
      "notes": "Flat-merge the collection snippets — one `export MERGE_<KEY>=...` line per collect node.",
      "parameters": {
        "command": "=export MERGE_ONE={{ $('Collect').item.json.stdout.base64Encode() }}\nmerge.sh --b64"
      },
      "position": [
        720,
        320
      ],
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1
    },
    {
      "id": "report",
      "name": "Report",
      "notes": "report.sh assembles merged + {validations} and renders the report markdown. With validators, add a 'Merge validations' node (merge.sh -k --b64) and `export VALS={{ $('Merge validations')...base64Encode() }}` here.",
      "parameters": {
        "command": "=export DATA={{ $('Merge snippets').item.json.stdout.base64Encode() }}\nexport NAMESPACE={{ ($('Webhook').item.json.query||{}).namespace }}\nreport.sh <group> <report>.md"
      },
      "position": [
        960,
        320
      ],
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1
    },
    {
      "id": "md2html",
      "name": "Markdown to HTML",
      "parameters": {
        "markdown": "={{ $json.stdout }}",
        "mode": "markdownToHtml",
        "options": {}
      },
      "position": [
        1200,
        320
      ],
      "type": "n8n-nodes-base.markdown",
      "typeVersion": 1
    },
    {
      "id": "respond",
      "name": "Respond to Webhook (HTML)",
      "parameters": {
        "options": {
          "responseHeaders": {
            "entries": [
              {
                "name": "Content-Type",
                "value": "text/html"
              }
            ]
          }
        },
        "respondWith": "text",
        "responseBody": "={{ $json.data }}"
      },
      "position": [
        1440,
        320
      ],
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1
    }
  ],
