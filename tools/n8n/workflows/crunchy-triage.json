      "name": "Verdicts",
      "parameters": {
        "jsCode": "const merged = JSON.parse(Buffer.from($('Merge + encode').item.json._b64, 'base64').toString());\nconst parseV = (n) => { try { return JSON.parse($(n).item.json.stdout || '{}'); } catch (e) { return {}; } };\nconst names = ['Validate cluster', 'Validate pgBackRest', 'Validate connections', 'Validate WAL', 'Validate cache'];\nconst validations = {};\nfor (const n of names) { const v = parseV(n); if (v && v.check) validations[v.check] = v; }\nconst final = { ...merged, validations };\nreturn [{ json: { ...final, _b64: Buffer.from(JSON.stringify(final)).toString('base64') } }];"
